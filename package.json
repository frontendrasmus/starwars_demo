{
  "name": "chat-demo-v1",
  "private": true,
  "version": "0.0.1",
  "description": "Custom chat UI + backend demo (assistant-ui + Hono + AI SDK)",
  "scripts": {
    "dev": "pnpm --parallel --stream -r dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "docs": "node scripts/generate-docs.mjs",
    "docs:dry": "node scripts/generate-docs.mjs --dry-run"
  },
  "packageManager": "pnpm@9.15.0"
}
